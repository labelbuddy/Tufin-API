ags\",\n\t\t\t\"requirement_name\": \"mandatory_financial_tags\",\n\t\t\t\"requirement_severity\": \"HIGH\",\n\t\t\t\"tags\": [\n\t\t\t\t\"Owner\",\n\t\t\t\t\"Budget\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"requirement_type\": \"valid_values\",\n\t\t\t\"requirement_name\": \"budget_valid_values\",\n\t\t\t\"requirement_severity\": \"CRITICAL\",\n\t\t\t\"tag\": \"Budget\",\n\t\t\t\"values\": [\n\t\t\t\t\"Corporate\",\n\t\t\t\t\"Dev\"\n\t\t\t]\n\t\t}\n\t]\n}|{\n\t\t\"status\": \"OK\",\n\t\t\"policy_id\": \"tp-123\"\n}"],"position":"","type":"TagPolicyResponseDTO","nickname":"create","produces":["application/json"],"consumes":["application/json"],"parameters":[{"name":"context","description":"Create policy for the specified domain ID","required":false,"type":"integer","format":"int32","paramType":"query","allowMultiple":false,"allowableValues":"","hidden":false},{"name":"body","rootElement":"TagPolicyDTO","description":"cloud tag policy DTO","required":false,"type":"TagPolicyDTO","format":"","paramType":"body","allowMultiple":false,"allowableValues":"","hidden":false}],"responseMessages":[{"code":200,"message":"Successful"},{"code":400,"message":"Invalid request"},{"code":403,"message":"Insufficient user permissions"},{"code":409,"message":"Policy name already exists"}]},{"baseURL":"/securetrack/api","method":"GET","summary":"Get all cloud tag policies","notes":"This API returns the details of all the tag policies.\u003cbr\u003e\u003cbr\u003eResults are filtered according to user domain permissions and request context. If the return code is not OK, the errorMessage field of the TagPolicyResponseDTO may contain additional details describing the cause of the error.","examples":["https://192.168.1.1/securetrack/api/tagpolicy/policies/ ||{\n\t\t\"status\": \"OK\",\n\t\t\"result\": [\n\t\t\t\t{\n\t\t\t\t\t\t\"policy_id\": \"tp-101\",\n\t\t\t\t\t\t\"policy_name\": \"myPolicy1\",\n\t\t\t\t\t\t\"requirements\": [\n\t\t\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\t\t\t\"requirement_type\": \"mandato